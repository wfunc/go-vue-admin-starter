# Go Vue Admin Starter
# Copy this file to .env for local docker-compose usage or export the variables manually.

APP_NAME=go-vue-admin-starter
APP_ENV=development

SERVER_HOST=0.0.0.0
SERVER_PORT=18080
SERVER_MODE=debug

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=go_vue_admin_starter
DATABASE_SSLMODE=disable
DATABASE_MAX_OPEN_CONNS=20
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME=30m

REDIS_ENABLED=true
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET=starter-secret-change-me
JWT_TTL=24h
JWT_ISSUER=go-vue-admin-starter

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123456
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_NICKNAME=Starter Admin

VITE_API_BASE_URL=/api/v1
VITE_DEV_PROXY_TARGET=http://backend:18080
VITE_DEV_PORT=5173
